<ui:FluentWindow x:Class="Anything_UI_WPF.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Anything_UI_WPF.Models"
             Title="{Binding WindowTitle}"
             Height="650" Width="980"
             WindowStartupLocation="CenterScreen"
             ExtendsContentIntoTitleBar="True"
             WindowBackdropType="Mica"
             WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Anything">
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <ui:Button x:Name="SettingsBtn"
                              ToolTip="{Binding LangSettings}"
                              Command="{Binding OpenSettingsCommand}"
                              Appearance="Transparent"
                              Padding="8,4"/>
                    <ui:Button x:Name="ThemeBtn"
                              ToolTip="{Binding ThemeTooltip}"
                              Command="{Binding ToggleThemeCommand}"
                              Appearance="Transparent"
                              Padding="8,4"/>
                    <ui:Button x:Name="AboutBtn"
                              ToolTip="{Binding LangAbout}"
                              Command="{Binding OpenAboutCommand}"
                              Appearance="Transparent"
                              Padding="8,4"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Border Grid.Row="1" Margin="16,8,16,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource ControlElevationBorderBrush}"/>
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Border.Style>
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" x:Name="SearchBox"
                             PlaceholderText="{Binding LangSearchPlaceholder}"
                            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                            ClearButtonEnabled="True"
                            Icon="Search24"
                            Margin="0,0,4,0"/>
                <ui:Button Grid.Column="1"
                          Icon="History24"
                          ToolTip="History"
                          Command="{Binding ToggleSearchHistoryCommand}"
                          Appearance="Transparent"
                          Padding="6,4"
                          Margin="0,0,4,0"/>
                <ComboBox Grid.Column="2"
                          SelectedItem="{Binding SearchType}"
                          VerticalAlignment="Center"
                          MinWidth="90"
                          ItemsSource="{Binding SearchTypes}"/>

                <Popup IsOpen="{Binding ShowSearchHistory, Mode=TwoWay}"
                       StaysOpen="False"
                       PlacementTarget="{Binding ElementName=SearchBox}"
                       Placement="Bottom"
                       Width="{Binding ActualWidth, ElementName=SearchBox}"
                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <Border Background="{DynamicResource ControlFillTertiaryBrush}"
                            CornerRadius="6"
                            Padding="4"
                            MaxHeight="300">
                        <ListBox ItemsSource="{Binding SearchHistory}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="SearchHistory_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Padding="6,4"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="16,8,16,0">
            <ListView x:Name="ResultsListView"
                      ItemsSource="{Binding Results}"
                      MouseDoubleClick="ResultsListView_MouseDoubleClick"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      BorderThickness="0"
                      Background="Transparent">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:FileSearchResult}">
                        <Border Padding="8,6" Margin="0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="CornerRadius" Value="4"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ControlFillTertiaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.LangContextOpen}"
                                              Command="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.OpenFileCommand}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.LangContextOpenFolder}"
                                              Command="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.OpenFileLocationCommand}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.LangContextCopyPath}"
                                              Command="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.CopyPathCommand}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.LangContextCopyFile}"
                                              Command="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.CopyFileCommand}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.LangContextProperties}"
                                              Command="{Binding Source={RelativeSource AncestorType=ListView}, Path=DataContext.ShowPropertiesCommand}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                          Text="{Binding Name}"
                                          FontWeight="SemiBold"
                                          FontSize="14"
                                          TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                          Text="{Binding DirectoryPath}"
                                          FontSize="11"
                                          Opacity="0.55"
                                          TextTrimming="CharacterEllipsis"
                                          Margin="0,0,16,0"/>
                                <TextBlock Grid.Column="2" Grid.Row="0"
                                          Text="{Binding SizeFormatted}"
                                          FontSize="12"
                                          VerticalAlignment="Center"
                                          Margin="0,0,24,0"/>
                                <TextBlock Grid.Column="3" Grid.Row="0"
                                          Text="{Binding LastModifiedFormatted}"
                                          FontSize="12"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                    <TextBlock Text="{Binding StatusText}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Margin="16,8,16,16">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0">
                <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
            <Separator Grid.Column="1"/>
            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding IndexSize, StringFormat='Index: {0:N0}'}" Margin="0,0,4,0"/>
                    <ui:Button Icon="ArrowRepeatAll24"
                              Command="{Binding RebuildIndexCommand}"
                               ToolTip="{Binding LangRebuildIndex}"
                              Appearance="Transparent"
                              Padding="4"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
