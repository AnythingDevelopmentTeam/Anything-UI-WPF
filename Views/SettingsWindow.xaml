<ui:FluentWindow x:Class="Anything_UI_WPF.Views.SettingsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:Services="clr-namespace:Anything_UI_WPF.Services"
             Title="{Binding WindowTitle}"
             Height="500" Width="520"
             WindowStartupLocation="CenterOwner"
             ResizeMode="CanResizeWithGrip"
             ExtendsContentIntoTitleBar="True"
             WindowBackdropType="Mica"
             WindowCornerPreference="Round">
    <Grid Margin="0,32,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding WindowTitle}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8,16,16">
                <ui:Card Margin="0,0,0,8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding LangGeneral}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding LangLanguage}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static Services:LanguageService.AvailableLanguages}}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding SelectedLanguage}"
                                      MinWidth="140"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding LangExcludedDirs}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        PlaceholderText="{Binding LangDirPlaceholder}"
                                        Text="{Binding NewDirPath, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1"
                                      Content="{Binding LangAddDir}"
                                      Command="{Binding AddDirCommand}"
                                      Appearance="Primary"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ExcludedDirectories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                                        <ui:Button Grid.Column="1"
                                                  Icon="Delete24"
                                                  Command="{Binding Source={RelativeSource AncestorType={x:Type ItemsControl}}, Path=DataContext.RemoveDirCommand}"
                                                  CommandParameter="{Binding}"
                                                  Appearance="Danger"
                                                  ToolTip="{Binding Source={RelativeSource AncestorType={x:Type ItemsControl}}, Path=DataContext.LangRemove}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Действия" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                        <ui:Button Content="{Binding LangRebuildIndex}"
                                  Command="{Binding RebuildIndexCommand}"
                                  Appearance="Primary"
                                  Icon="ArrowRepeatAll24"/>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
